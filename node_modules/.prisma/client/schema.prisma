generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     String
  status   String   @default("ACTIVE")
  records  Record[]
}

model Record {
  id        Int      @id @default(autoincrement())
  amount    Float
  type      String
  category  String
  notes     String?
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Budget {
  id       Int    @id @default(autoincrement())
  category String
  limit    Float
}
